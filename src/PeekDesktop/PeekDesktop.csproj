<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>PeekDesktop</AssemblyName>
    <RootNamespace>PeekDesktop</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Version>1.0.1-beta.1</Version>
    <Authors>Scott Hanselman</Authors>
    <Description>Click your desktop to peek at it — just like macOS Sonoma.</Description>
    <RepositoryUrl>https://github.com/shanselman/PeekDesktop</RepositoryUrl>
  </PropertyGroup>

</Project>
